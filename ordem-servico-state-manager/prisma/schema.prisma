generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ServiceOrderStatus {
  CREATED
  DIAGNOSIS_IN_PROGRESS
  WAITING_APPROVAL
  APPROVED
  REPAIR_IN_PROGRESS
  FINAL_TEST
  COMPLETED
  CANCELLED
}

model ServiceOrder {
  id          String              @id
  status      ServiceOrderStatus
  customerId  String
  vehicleId   String
  complaint   String?
  assignedTo  String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  completedAt DateTime?
  cancelledAt DateTime?
  version     Int                 @default(1)
  events      Event[]
  @@map("service_orders")
}

model Event {
  id          String       @id @default(cuid())
  orderId     String
  order       ServiceOrder @relation(fields: [orderId], references: [id])
  eventType   String
  title       String
  description String?
  metadata    Json?
  occurredAt  DateTime
  @@map("events")
}
